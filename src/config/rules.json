{
  "version": "4.0",
  "ruleset": "base_only_1v4_10.0.2",
  "prototypeThresholdNotice": "所有默认阈值均为原型待验证数值，不代表官方标准或经过真实对局数据验证的结论。",
  "maxDisplayedMetrics": 3,
  "severityBands": {
    "highMinScore": 2,
    "criticalMinScore": 3
  },
  "priority": [
    "FIRST_CHASE_START_TOO_LATE",
    "AVERAGE_CHASE_TOO_LONG",
    "LATE_FIRST_ELIMINATION"
  ],
  "rules": {
    "FIRST_CHASE_START_TOO_LATE": {
      "enabled": true,
      "thresholdMs": 30000,
      "minimumSampleSize": 1,
      "baseSeverity": 1,
      "deviationWeight": 1,
      "confidence": 1
    },
    "LATE_FIRST_ELIMINATION": {
      "enabled": true,
      "maximumGeneratorsRemaining": 1,
      "minimumSampleSize": 1,
      "baseSeverity": 1,
      "deviationWeight": 1,
      "confidence": 1,
      "noEliminationRelativeDeviation": 1
    },
    "AVERAGE_CHASE_TOO_LONG": {
      "enabled": true,
      "thresholdMs": 40000,
      "minimumSampleSize": 2,
      "baseSeverity": 1,
      "deviationWeight": 1,
      "confidence": 1
    }
  }
}
